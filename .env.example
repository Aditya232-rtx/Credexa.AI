# Credexa Environment Configuration Example

# Required for AES-256 encryption at rest (generate using cryptography.fernet.Fernet.generate_key())
ENCRYPTION_KEY="your-32-url-safe-base64-encoded-key="

# Database connection
DB_DSN="dbname=credexa user=adityajadhav host=localhost port=5432"

# API Authentication (Required for Production)
CREDEXA_API_KEY="your-secure-api-key"

# Ollama LLM Config
OLLAMA_MODEL="qwen3.5:4b"
OLLAMA_URL="http://localhost:11434"

# Optional: Disable internet access for offline deployment
# HF_HUB_OFFLINE=1
